# ─────────────────────────────────────────────────────────────────────────────
# Конфигурация бэкенда. Скопируй в `.env` и заполни.
# На сервере этот файл создаётся автоматически скриптом deploy/setup-server.sh.
# ─────────────────────────────────────────────────────────────────────────────

# Подключение к PostgreSQL (на том же сервере)
DATABASE_URL=postgres://aladdin:ПАРОЛЬ@127.0.0.1:5432/aladdin

# Секрет для подписи JWT-токенов. Сгенерируй: openssl rand -hex 32
JWT_SECRET=замени_на_длинную_случайную_строку
JWT_EXPIRES=7d

# Где слушает API (наружу не выставляется — только Nginx ходит на localhost)
HOST=127.0.0.1
PORT=3001

# Хранилище загруженных счетов/файлов
UPLOAD_DIR=/var/www/aladdin-travel-pay/backend/uploads
MAX_UPLOAD_MB=25

# Первичный администратор (создаётся командой `npm run seed`, только если ещё нет)
ADMIN_EMAIL=admin@alladin.club
ADMIN_PASSWORD=задай_надёжный_пароль
ADMIN_NAME=Администратор
