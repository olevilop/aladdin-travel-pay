# ─────────────────────────────────────────────────────────────────────────────
# Конфигурация Telegram-бота. Скопируй в `.env` и заполни.
#   cp .env.example .env
# На сервере этот файл создаёт скрипт deploy/setup-bot.sh.
# ─────────────────────────────────────────────────────────────────────────────

# Токен бота от @BotFather (выглядит как 123456789:AA...)
TELEGRAM_BOT_TOKEN=

# Адрес нашего backend (на том же сервере)
BACKEND_URL=http://127.0.0.1:3001

# Сервисный токен — ДОЛЖЕН совпадать с BOT_API_TOKEN из backend/.env
BOT_API_TOKEN=

# Кто может пользоваться ботом — Telegram id через запятую (узнать: команда /id боту).
# Если оставить пустым — бот примет файлы от кого угодно (НЕБЕЗОПАСНО).
ALLOWED_USER_IDS=
